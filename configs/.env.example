# ============================================================
# AI Reception — Environment Variables
# Copy this file to configs/.env and fill in real values.
# NEVER commit the .env file to git.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
SERVER_URL=https://your-backend.up.railway.app
FRONTEND_URL=http://localhost:4000

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=replace_with_random_64char_string_here

# ── Railway PostgreSQL ───────────────────────────────────────
# Provided automatically when you add a PostgreSQL service in Railway.
# Copy the "DATABASE_URL" from Railway → your Postgres service → Variables.
DATABASE_URL=postgresql://postgres:password@containers-us-west-xxx.railway.app:5432/railway

# ── Anthropic (Claude AI) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio (Voice + SMS + WhatsApp) ─────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── ElevenLabs (Text-to-Speech) ─────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Deepgram (Speech-to-Text) ───────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── OpenAI (RAG Embeddings — optional but recommended) ──────
OPENAI_API_KEY=sk-...

# ── Google Calendar (optional) ──────────────────────────────
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
# Paste the entire JSON of your Google service account key on one line:
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# ── Email (Nodemailer via Gmail) ─────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_USER=your-hotel@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="Oyugis Le Grand Hotel <your-hotel@gmail.com>"

# ── Hotel Config ─────────────────────────────────────────────
HOTEL_NAME=Oyugis Le Grand Hotel
HOTEL_TIMEZONE=Africa/Nairobi
WORKING_HOURS_START=06:00
WORKING_HOURS_END=22:00

# ── Frontend (Next.js) ───────────────────────────────────────
NEXTAUTH_URL=http://localhost:4000
NEXTAUTH_SECRET=replace_with_random_secret
NEXT_PUBLIC_API_URL=http://localhost:3000
